from rest "/servicesNS/-/-/saved/searches"
| fields title eai:data.id eai:acl.app eai:acl.owner is_scheduled alert_type

/* Build unique URI */
| eval uri="/servicesNS/" . eai:acl.owner . "/" . eai:acl.app . "/saved/searches/" . eai:data.id

/* Hash */
| eval hash=sha256(uri)

/* Check KV store */
| lookup ABC hash OUTPUT hash as existing_hash
| where isnull(existing_hash)

/* Metadata */
| eval savedsearch_name=title,
       app=eai:acl.app,
       owner=eai:acl.owner,
       created_at=now()

/* Derive category */
| eval category=case(
    alert_type="always" OR is_scheduled=1, "ALERT",
    is_scheduled=0, "ADHOC",
    true(), "SS"
)

/* Get max serial */
| appendcols [
    | from inputlookup:ABC
    | stats max(serial_num) as max_serial
]

| eval max_serial=coalesce(max_serial, 0)

/* Increment */
| streamstats count as increment
| eval serial_num=max_serial + increment

/* Final formatted serial */
| eval serial="SPL-" . category . "-" . tostring(serial_num)

/* KV key */
| eval _key=hash

| fields _key hash uri savedsearch_name app owner category created_at serial serial_num

| into ABC